DATABASE_URL=postgres://postgres:postgres@localhost:5432/kahoot
DATABASE_SSL=false
# Set to true only if your Postgres uses a self-signed cert (skips cert chain validation)
DATABASE_SSL_NO_VERIFY=false
# Set to true only if behind a corporate proxy with a self-signed root CA
ALLOW_INSECURE_TLS=false
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
JWT_SECRET=your_jwt_secret
SESSION_SECRET=your_session_secret

# AI Generation
AI_PROVIDER=straico
AI_FALLBACK_PROVIDER=openrouter
OPENAI_API_KEY=your_openai_api_key
STRAICO_API_KEY=your_straico_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
